# openMiura profile: local-secure
# Local single-node deployment with auth, cookies and vault turned on.
# Replace placeholder credentials before first real use.

OPENMIURA_CONFIG=configs/openmiura.yaml
OPENMIURA_SERVER_HOST=127.0.0.1
OPENMIURA_SERVER_PORT=8081
OPENMIURA_DB_BACKEND=sqlite
OPENMIURA_DB_PATH=data/audit.db
OPENMIURA_DB_AUTO_MIGRATE=true
OPENMIURA_LLM_PROVIDER=ollama
OPENMIURA_LLM_BASE_URL=http://127.0.0.1:11434
OPENMIURA_LLM_MODEL=qwen2.5:7b-instruct
OPENMIURA_EMBED_BASE_URL=http://127.0.0.1:11434
OPENMIURA_EMBED_MODEL=nomic-embed-text
OPENMIURA_WORKER_MODE=external
OPENMIURA_ADMIN_ENABLED=true
OPENMIURA_ADMIN_TOKEN=replace-me
OPENMIURA_AUTH_ENABLED=true
OPENMIURA_UI_ADMIN_USERNAME=admin
OPENMIURA_UI_ADMIN_PASSWORD=
OPENMIURA_AUTH_COOKIE_ENABLED=true
OPENMIURA_AUTH_COOKIE_SECURE=false
OPENMIURA_AUTH_CSRF_ENABLED=true
OPENMIURA_BROKER_ENABLED=true
OPENMIURA_BROKER_TOKEN=replace-me
OPENMIURA_MCP_ENABLED=false
OPENMIURA_VAULT_ENABLED=true
OPENMIURA_VAULT_PASSPHRASE=replace-me
OPENMIURA_SECRETS_ENABLED=true
OPENMIURA_WEB_FETCH_ALLOW_ALL_DOMAINS=false
OPENMIURA_WEB_FETCH_ALLOWED_DOMAINS=
OPENMIURA_TERMINAL_ENABLED=false
OPENMIURA_TERMINAL_ALLOW_SHELL=false
OPENMIURA_TERMINAL_ALLOW_METACHARACTERS=false
OPENMIURA_TERMINAL_REQUIRE_EXPLICIT_ALLOWLIST=true
OPENMIURA_TERMINAL_ALLOWED_COMMANDS=
OPENMIURA_CONTROL_ALLOW_SELF_RESTART=false
