OPENMIURA_CONFIG=configs/openmiura.yaml
OPENMIURA_SERVER_HOST=127.0.0.1
OPENMIURA_SERVER_PORT=8081
OPENMIURA_DB_BACKEND=sqlite
OPENMIURA_DB_PATH=data/audit.db
OPENMIURA_DATABASE_URL=
OPENMIURA_BACKUP_DIR=data/backups
OPENMIURA_DB_AUTO_MIGRATE=true
OPENMIURA_LLM_PROVIDER=ollama
OPENMIURA_LLM_BASE_URL=http://127.0.0.1:11434
OPENMIURA_LLM_MODEL=qwen2.5:7b-instruct
OPENMIURA_LLM_TIMEOUT_S=60
OPENMIURA_EMBED_BASE_URL=http://127.0.0.1:11434
OPENMIURA_EMBED_MODEL=nomic-embed-text
OPENMIURA_WORKER_MODE=external
OPENMIURA_SANDBOX_DIR=data/sandbox
OPENMIURA_UI_ADMIN_USERNAME=admin
OPENMIURA_UI_ADMIN_PASSWORD=change-me
OPENMIURA_BROKER_HOST=127.0.0.1
OPENMIURA_BROKER_PORT=8081
OPENMIURA_BROKER_BASE_PATH=/broker
OPENMIURA_MCP_HOST=127.0.0.1
OPENMIURA_MCP_PORT=8091
OPENMIURA_MCP_SSE_PATH=/mcp
OPENMIURA_VAULT_ENABLED=false
OPENMIURA_SECRETS_ENABLED=false
OPENMIURA_SECRETS_REDACT_LOGS=true
OPENMIURA_TERMINAL_SHELL=
OPENMIURA_TERMINAL_ALLOWED_COMMANDS=
OPENMIURA_TERMINAL_BLOCKED_COMMANDS=
OPENMIURA_TERMINAL_BLOCKED_PATTERNS=
VOICE_STT_PROVIDER=local
VOICE_TTS_PROVIDER=local
PWA_BASE_URL=http://localhost:8081
OPENMIURA_CONTROL_ALLOW_SELF_RESTART=false
OPENMIURA_CONTROL_SELF_RESTART_COMMAND=
OPENMIURA_TELEGRAM_BOT_TOKEN=
OPENMIURA_TELEGRAM_MODE=polling
OPENMIURA_TELEGRAM_WEBHOOK_SECRET=
OPENMIURA_SLACK_BOT_TOKEN=
OPENMIURA_SLACK_SIGNING_SECRET=
OPENMIURA_SLACK_BOT_USER_ID=
OPENMIURA_DISCORD_BOT_TOKEN=
OPENMIURA_DISCORD_APPLICATION_ID=
# Permissive local developer profile
OPENMIURA_ADMIN_ENABLED=false
OPENMIURA_ADMIN_TOKEN=change-me
OPENMIURA_AUTH_ENABLED=false
OPENMIURA_AUTH_COOKIE_SECURE=false
OPENMIURA_AUTH_CSRF_ENABLED=false
OPENMIURA_BROKER_ENABLED=false
OPENMIURA_BROKER_TOKEN=
OPENMIURA_MCP_ENABLED=false
OPENMIURA_WEB_FETCH_ALLOW_ALL_DOMAINS=true
OPENMIURA_WEB_FETCH_ALLOWED_DOMAINS=
OPENMIURA_WEB_FETCH_BLOCK_PRIVATE_IPS=false
OPENMIURA_TERMINAL_ENABLED=true
OPENMIURA_TERMINAL_ALLOW_SHELL=true
OPENMIURA_TERMINAL_ALLOW_METACHARACTERS=true
OPENMIURA_TERMINAL_REQUIRE_EXPLICIT_ALLOWLIST=false
