# openMiura environment catalog
# ----------------------------
# Use one of the ready-made profile templates in ops/env/ as your starting point:
#   - ops/env/local-secure.env   (recommended first-start profile)
#   - ops/env/local-dev.env
#   - ops/env/secure-default.env
#   - ops/env/insecure-dev.env
#   - ops/env/demo.env
#   - ops/env/production-like.env
#
# This file is the canonical variable reference. It is intentionally more complete
# than any one profile and should not contain duplicate keys.
# Never commit a real .env file with live secrets.

# Config file selection
OPENMIURA_CONFIG=configs/openmiura.yaml

# Server
OPENMIURA_SERVER_HOST=127.0.0.1
OPENMIURA_SERVER_PORT=8081

# Storage
OPENMIURA_DB_BACKEND=sqlite
OPENMIURA_DB_PATH=data/audit.db
OPENMIURA_DATABASE_URL=
OPENMIURA_BACKUP_DIR=data/backups
OPENMIURA_DB_AUTO_MIGRATE=true

# LLM and embeddings
OPENMIURA_LLM_PROVIDER=ollama
OPENMIURA_LLM_BASE_URL=http://127.0.0.1:11434
OPENMIURA_LLM_MODEL=qwen2.5:7b-instruct
OPENMIURA_LLM_TIMEOUT_S=60
OPENMIURA_LLM_API_KEY_ENV_VAR=
OPENMIURA_ANTHROPIC_VERSION=2023-06-01
OPENMIURA_LLM_MAX_OUTPUT_TOKENS=2048
OPENMIURA_EMBED_BASE_URL=http://127.0.0.1:11434
OPENMIURA_EMBED_MODEL=nomic-embed-text

# Runtime
OPENMIURA_WORKER_MODE=external
OPENMIURA_SANDBOX_DIR=data/sandbox

# Admin and UI bootstrap
OPENMIURA_ADMIN_ENABLED=false
OPENMIURA_ADMIN_TOKEN=change-me
OPENMIURA_AUTH_ENABLED=true
OPENMIURA_UI_ADMIN_USERNAME=admin
OPENMIURA_UI_ADMIN_PASSWORD=change-me

# Auth session controls
OPENMIURA_AUTH_SESSION_TTL_S=86400
OPENMIURA_AUTH_SESSION_IDLE_TTL_S=0
OPENMIURA_AUTH_MAX_SESSIONS_PER_USER=0
OPENMIURA_AUTH_SESSION_ROTATION_INTERVAL_S=0
OPENMIURA_AUTH_API_TOKEN_DEFAULT_TTL_S=0
OPENMIURA_AUTH_API_TOKEN_IDLE_TTL_S=0
OPENMIURA_AUTH_API_TOKEN_ROTATION_INTERVAL_S=0
OPENMIURA_AUTH_COOKIE_ENABLED=false
OPENMIURA_AUTH_COOKIE_NAME=openmiura_session
OPENMIURA_AUTH_COOKIE_SECURE=false
OPENMIURA_AUTH_COOKIE_SAMESITE=lax
OPENMIURA_AUTH_CSRF_ENABLED=false
OPENMIURA_AUTH_CSRF_COOKIE_NAME=openmiura_csrf
OPENMIURA_AUTH_CSRF_HEADER_NAME=X-CSRF-Token

# Broker and MCP
OPENMIURA_BROKER_ENABLED=false
OPENMIURA_BROKER_HOST=127.0.0.1
OPENMIURA_BROKER_PORT=8081
OPENMIURA_BROKER_BASE_PATH=/broker
OPENMIURA_BROKER_TOKEN=
OPENMIURA_BROKER_RATE_LIMIT_PER_MINUTE=120
OPENMIURA_BROKER_AUTH_RATE_LIMIT_PER_MINUTE=20
OPENMIURA_MCP_ENABLED=false
OPENMIURA_MCP_HOST=127.0.0.1
OPENMIURA_MCP_PORT=8091
OPENMIURA_MCP_SSE_PATH=/mcp

# Channels
OPENMIURA_TELEGRAM_BOT_TOKEN=
OPENMIURA_TELEGRAM_MODE=polling
OPENMIURA_TELEGRAM_WEBHOOK_SECRET=
OPENMIURA_SLACK_BOT_TOKEN=
OPENMIURA_SLACK_SIGNING_SECRET=
OPENMIURA_SLACK_BOT_USER_ID=
OPENMIURA_DISCORD_BOT_TOKEN=
OPENMIURA_DISCORD_APPLICATION_ID=

# Memory vault and secrets governance
OPENMIURA_VAULT_ENABLED=false
OPENMIURA_VAULT_PASSPHRASE=
OPENMIURA_SECRETS_ENABLED=false
OPENMIURA_SECRETS_REDACT_LOGS=true

# Network and terminal posture (secure-by-default)
OPENMIURA_WEB_FETCH_ALLOW_ALL_DOMAINS=false
OPENMIURA_WEB_FETCH_ALLOWED_DOMAINS=
OPENMIURA_WEB_FETCH_BLOCK_PRIVATE_IPS=true
OPENMIURA_TERMINAL_ENABLED=false
OPENMIURA_TERMINAL_SHELL=
OPENMIURA_TERMINAL_ALLOW_SHELL=false
OPENMIURA_TERMINAL_ALLOW_METACHARACTERS=false
OPENMIURA_TERMINAL_REQUIRE_EXPLICIT_ALLOWLIST=true
OPENMIURA_TERMINAL_ALLOWED_COMMANDS=
OPENMIURA_TERMINAL_BLOCKED_COMMANDS=
OPENMIURA_TERMINAL_BLOCKED_PATTERNS=

# Voice/PWA integration
VOICE_STT_PROVIDER=local
VOICE_TTS_PROVIDER=local
VOICE_STT_WEBHOOK_URL=
VOICE_TTS_WEBHOOK_URL=
PWA_BASE_URL=http://localhost:8081

# Config Center: optional external restart hook
OPENMIURA_CONTROL_ALLOW_SELF_RESTART=false
OPENMIURA_CONTROL_SELF_RESTART_COMMAND=
