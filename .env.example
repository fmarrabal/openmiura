# openMiura example environment
# Copy to .env for local use and replace placeholder values.
# Never commit real secrets.

OPENMIURA_SERVER_HOST=127.0.0.1
OPENMIURA_SERVER_PORT=8081
OPENMIURA_DB_BACKEND=sqlite
OPENMIURA_DB_PATH=data/audit.db
OPENMIURA_DB_AUTO_MIGRATE=true

OPENMIURA_LLM_PROVIDER=ollama
OPENMIURA_LLM_BASE_URL=http://127.0.0.1:11434
OPENMIURA_LLM_MODEL=qwen2.5:7b-instruct
OPENMIURA_EMBED_BASE_URL=http://127.0.0.1:11434
OPENMIURA_EMBED_MODEL=nomic-embed-text

OPENMIURA_ADMIN_ENABLED=false
OPENMIURA_ADMIN_TOKEN=change-me
OPENMIURA_BROKER_ENABLED=false
OPENMIURA_BROKER_TOKEN=

OPENMIURA_AUTH_ENABLED=true
OPENMIURA_UI_ADMIN_USERNAME=admin
OPENMIURA_UI_ADMIN_PASSWORD=change-me

OPENMIURA_TELEGRAM_BOT_TOKEN=
OPENMIURA_SLACK_BOT_TOKEN=
OPENMIURA_SLACK_SIGNING_SECRET=
OPENMIURA_DISCORD_BOT_TOKEN=

OPENMIURA_VAULT_ENABLED=false
OPENMIURA_VAULT_PASSPHRASE=
OPENMIURA_SECRETS_ENABLED=false

VOICE_STT_PROVIDER=local
VOICE_TTS_PROVIDER=local
VOICE_STT_WEBHOOK_URL=
VOICE_TTS_WEBHOOK_URL=

PWA_BASE_URL=http://localhost:8081
